{
  "expo": {
    "name": "Oracle: AI Life Advisor",
    "slug": "oracle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "oracle",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#04040f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.theoracle.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Oracle uses your camera to capture biometric reference images (your hand and face) used as the input signal for your behavioral analysis. Images are sent securely for analysis and never stored.",
        "NSPhotoLibraryUsageDescription": "Oracle uses your photo library so you can choose existing biometric reference images for your behavioral analysis."
      },
      "associatedDomains": ["applinks:theoracle.app"]
    },
    "android": {
      "backgroundColor": "#04040f",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0d0015"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "theoracle.app",
              "pathPrefix": "/invite"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-image-picker",
      "expo-camera",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#c9a84c"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "baseUrl": "/oracle"
    }
  }
}
